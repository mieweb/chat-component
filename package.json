{
  "name": "@mieweb/chat-component",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/chat-component.umd.js",
  "module": "./dist/chat-component.es.js",
  "exports": {
    ".": {
      "import": "./dist/chat-component.es.js",
      "require": "./dist/chat-component.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "preview": "vite preview",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "keywords": [
    "react",
    "chat",
    "component",
    "tailwind",
    "zustand"
  ],
  "author": "MIE Web",
  "license": "ISC",
  "description": "A React chat component with Tailwind CSS and Zustand state management",
  "repository": {
    "type": "git",
    "url": "https://github.com/mieweb/chat-component.git"
  },
  "homepage": "https://github.com/mieweb/chat-component#readme",
  "bugs": {
    "url": "https://github.com/mieweb/chat-component/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^3.4.18",
    "vite": "^8.0.16"
  }
}
